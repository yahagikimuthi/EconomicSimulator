{
    "name": "C++ Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "cmake.generator": "Ninja",
                "cmake.configureArgs": [
                    "-DCMAKE_TOOLCHAIN_FILE=/usr/local/vcpkg/scripts/buildsystems/vcpkg.cmake"
                ],
                "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
                "clangd.arguments": [
                    "--compile-commands-dir=${workspaceFolder}"
                ]
            },
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "ms-python.python", // Python言語サポート (デバッグ・インテリセンス)
                "ms-python.vscode-pylance" // 高速な型解析
            ]
        }
    },
    // コンテナ内の環境変数として GCC 14 を明示的に優先させる
    "containerEnv": {
        "CC": "/usr/bin/gcc-14",
        "CXX": "/usr/bin/g++-14"
    },
    "remoteUser": "vscode",
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ]
}